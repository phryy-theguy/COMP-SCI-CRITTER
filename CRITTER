import java.util.Random;  
public class Critter
{    
    private String type;    
    private String symbol;     
    public Critter(String type, String symbol) 
    {        
        this.type   = type;         
        this.symbol = symbol;    
    }     
    public int[] move(int row, int col, int gridSize) 
    {        
        Random rand = new Random();                  
        int direction = rand.nextInt(4);                   
        int newRow = row;                  
        int newCol = col;                   
        if (direction == 0)          
        {             
            newRow = row - 1;        
        }          
        else if (direction == 1)          
        {             
            newRow = row + 1;         
        }          
        else if (direction == 2)          
        {            
            newCol = col - 1;         
        }          
        else if (direction == 3)          
        {             
            newCol = col + 1;         
        }                  
        newRow = Math.max(0, Math.min(gridSize - 1, newRow));                  
        newCol = Math.max(0, Math.min(gridSize - 1, newCol));                   
        return new int[]{newRow, newCol};     
    }      
    
    public String interact(Critter other) 
    {         
        return getType() + " and " + other.getType() + " meet — nothing happens.";     
    }      
    public String getSymbol() 
    { 
        return symbol; 
    }     
    public String getType()   
    { 
        return type;   
    }     
    @Override     
    public String toString()  
    { 
        return symbol; 
    } 
}
